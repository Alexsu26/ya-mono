# syntax=docker/dockerfile:1.7

FROM ghcr.io/astral-sh/uv:python3.13-bookworm-slim AS builder

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates git

WORKDIR /workspace

COPY . .

RUN --mount=type=cache,target=/root/.cache/uv uv build --package ya-agent-platform -o /dist


FROM python:3.13-slim-bookworm AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    UV_LINK_MODE=copy

WORKDIR /srv/ya-agent-platform

COPY --from=builder /usr/local/bin/uv /usr/local/bin/uv
COPY --from=builder /dist /tmp/dist
RUN --mount=type=cache,target=/root/.cache/uv \
    platform_wheel=$(ls /tmp/dist/ya_agent_platform-*.whl) \
    && uv pip install --system "${platform_wheel}" \
    && rm -rf /tmp/dist

CMD ["python", "-c", "print('ya-agent-platform is a WIP stateless agent service with TBD scope. Current runtime work focuses on the single-node ya-claw build.')"]

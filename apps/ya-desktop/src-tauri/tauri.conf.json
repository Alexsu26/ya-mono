{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "height": 840,
        "minHeight": 720,
        "minWidth": 1024,
        "title": "YA Desktop",
        "width": 1280
      }
    ]
  },
  "build": {
    "beforeBuildCommand": "corepack pnpm build",
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [],
    "targets": "all"
  },
  "identifier": "com.wh1isper.ya-desktop",
  "productName": "YA Desktop",
  "version": "0.0.0"
}

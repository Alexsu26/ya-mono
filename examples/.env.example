# Example runtime environment variables for ya-agent-sdk examples
# Copy this file to examples/.env and uncomment the variables you need.

# =============================================================================
# Web Search API Keys
# =============================================================================

# GOOGLE_SEARCH_API_KEY=your_google_search_api_key
# GOOGLE_SEARCH_CX=your_google_search_cx
# TAVILY_API_KEY=your_tavily_api_key
# BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# =============================================================================
# Image Search API Keys
# =============================================================================

# PIXABAY_API_KEY=your_pixabay_api_key
# RAPIDAPI_API_KEY=your_rapidapi_key

# =============================================================================
# Web Scraping API Keys
# =============================================================================

# FIRECRAWL_API_KEY=your_firecrawl_api_key

# =============================================================================
# Agent Configuration (YA_AGENT_ prefix)
# =============================================================================

# YA_AGENT_IMAGE_UNDERSTANDING_MODEL=gpt-4o-mini
# YA_AGENT_IMAGE_UNDERSTANDING_MODEL_SETTINGS=anthropic_off
# YA_AGENT_VIDEO_UNDERSTANDING_MODEL=gemini-2.0-flash
# YA_AGENT_VIDEO_UNDERSTANDING_MODEL_SETTINGS=anthropic_off
# YA_AGENT_AUDIO_UNDERSTANDING_MODEL=gemini-2.0-flash
# YA_AGENT_AUDIO_UNDERSTANDING_MODEL_SETTINGS=gemini_thinking_level_low
# YA_AGENT_COMPACT_MODEL=gemini-2.0-flash
# YA_AGENT_LOG_LEVEL=WARNING

# =============================================================================
# OpenAI Responses WebSocket Transport
# =============================================================================

# Controls the SDK core OpenAI Responses WebSocket transport used by
# openai-responses-ws:<model> / openai-responses-rs:<model>.
# Allowed values: auto, websocket, http.
# YA_AGENT_OPENAI_RESPONSES_WEBSOCKET_MODE=auto

# Controls the Codex OAuth provider transport for oauth@codex:<model>.
# Allowed values: auto, websocket, http.
# YA_OAUTH_CODEX_RESPONSES_TRANSPORT=auto

# Shell review eval configuration.
# Copy this file to .env and provide provider credentials in the environment or this file.

SHELL_REVIEW_MODEL="gateway@openai-responses:gpt-5.4-mini"
SHELL_REVIEW_MODEL_SETTINGS="openai_responses_low"
SHELL_REVIEW_RISK_THRESHOLD="high"
SHELL_REVIEW_OUTPUT_JSONL="shell_review_eval_results.jsonl"
SHELL_REVIEW_CONCURRENCY="1"
SHELL_REVIEW_STRICT="false"
SHELL_REVIEW_CASES=""

# Gateway credentials for models like gateway@openai-responses:gpt-5.4-mini.
GATEWAY_API_KEY=""
GATEWAY_BASE_URL=""

# YA Claw runtime environment variables
# Copy this file to packages/ya-claw/.env and uncomment the variables you need.
# SDK and tool environment variables live in packages/ya-agent-sdk/.env.example.

# =============================================================================
# YA Claw Configuration (YA_CLAW_ prefix)
# =============================================================================

# YA_CLAW_ENVIRONMENT=development
# YA_CLAW_HOST=127.0.0.1
# YA_CLAW_PORT=9042
# YA_CLAW_LOG_LEVEL=INFO
# YA_CLAW_PUBLIC_BASE_URL=http://127.0.0.1:9042
# YA_CLAW_SERVICE_VERSION=dev
# YA_CLAW_SERVICE_COMMIT=local
# YA_CLAW_SERVICE_BUILD=dev-local
# YA_CLAW_SERVICE_IMAGE=ya-claw:dev
# YA_CLAW_INSTANCE_ID=host-pid-random
# YA_CLAW_API_TOKEN=replace-with-a-long-random-token
# YA_CLAW_AUTO_MIGRATE=true
# YA_CLAW_DATA_DIR=~/.ya-claw/data
# YA_CLAW_WORKSPACE_DIR=~/.ya-claw/data/workspace
# Default SQLite path: ~/.ya-claw/ya_claw.sqlite3
# YA_CLAW_DATABASE_URL=postgresql+psycopg://ya_claw:ya_claw@localhost:15433/ya_claw
# YA_CLAW_DATABASE_ECHO=false
# YA_CLAW_DATABASE_POOL_SIZE=5
# YA_CLAW_DATABASE_MAX_OVERFLOW=10
# YA_CLAW_DATABASE_POOL_RECYCLE_SECONDS=3600
# YA_CLAW_WEB_DIST_DIR=apps/ya-claw-web/dist
# YA_CLAW_DEFAULT_PROFILE=default
# Retry interrupted provider/SSE streams by resuming from recovered message history.
# YA_CLAW_AGENT_STREAM_RESUME_ON_ERROR=true
# YA_CLAW_AGENT_STREAM_RESUME_MAX_ATTEMPTS=2
# YA_CLAW_AGENT_STREAM_RESUME_PROMPT=The previous streaming model request failed before the agent finished. Continue the task from the available conversation history. Avoid repeating completed work.
# Proactively refresh OAuth-backed model provider tokens during service lifetime.
# YA_CLAW_OAUTH_REFRESH_ENABLED=true
# YA_CLAW_OAUTH_REFRESH_INTERVAL_SECONDS=1800
# YA_CLAW_OAUTH_REFRESH_FAILURE_RETRY_SECONDS=60
# YA_CLAW_OAUTH_REFRESH_ON_STARTUP=true
# Bundled profile seed lives at packages/ya-claw/profiles.yaml
# YA_CLAW_PROFILE_SEED_FILE=packages/ya-claw/profiles.yaml
# YA_CLAW_AUTO_SEED_PROFILES=true
# YA_CLAW_WORKSPACE_PROVIDER_BACKEND=local
# Official Debian stable workspace image with Python, Node.js, lark-cli, and bundled workspace skills
# YA_CLAW_WORKSPACE_PROVIDER_DOCKER_IMAGE=ghcr.io/wh1isper/ya-claw-workspace:latest
# Docker daemon-visible host path for workspace mounts. Set this when the YA Claw service runs in Docker.
# YA_CLAW_WORKSPACE_PROVIDER_DOCKER_HOST_WORKSPACE_DIR=/srv/ya-claw/workspace
# Defaults to the YA Claw service process UID/GID and is passed to auto-started workspace containers.
# Docker exec uses UID:GID by default so shell commands write files as the workspace identity.
# YA_CLAW_WORKSPACE_PROVIDER_DOCKER_UID=1000
# YA_CLAW_WORKSPACE_PROVIDER_DOCKER_GID=1000
# Docker exec user. Use auto for UID:GID, root for root exec, or a custom Docker user such as 1000:1000.
# YA_CLAW_WORKSPACE_PROVIDER_DOCKER_EXEC_USER=auto
# Default HOME used by Docker exec commands.
# YA_CLAW_WORKSPACE_PROVIDER_DOCKER_HOME=/home/claw
# Docker session sandboxes reuse one active container generation per session.
# Schedule and heartbeat runs use run-scoped Docker sandboxes and terminal cleanup.
# Container metadata cache defaults to ~/.ya-claw/data/docker-workspace-containers
# Session cache path: sessions/{session_id}/workspace.json
# Run cache path: runs/{run_id}/workspace.json
# Cache metadata stores the current Docker image digest; digest changes recreate the container from the current image.
# YA_CLAW_WORKSPACE_PROVIDER_DOCKER_CONTAINER_CACHE_DIR=~/.ya-claw/data/docker-workspace-containers
# Session sandbox retention policy: stop_on_idle or keep_warm.
# stop_on_idle refreshes last_used_at during active runs and once on run exit.
# YA_CLAW_WORKSPACE_PROVIDER_DOCKER_RETENTION_POLICY=stop_on_idle
# YA_CLAW_WORKSPACE_PROVIDER_DOCKER_IDLE_TTL_SECONDS=3600
# Comma-separated host_path:container_path[:mode] entries mounted into Docker workspace containers.
# Supported modes: rw, ro.
# YA_CLAW_WORKSPACE_PROVIDER_DOCKER_EXTRA_MOUNTS=/srv/ya-claw/home:/home/claw:rw,/srv/ya-claw/cache:/cache:ro
# Comma-separated process environment variable names to forward into workspace environments.
# Values stay in the process environment and are passed to local shells or Docker container creation.
# YA_CLAW_WORKSPACE_ENV_VARS=MY_TOOL_API_KEY,MY_TOOL_ENDPOINT
# Production allocator tuning used by the official Docker images. These values reduce glibc arena growth
# and encourage heap trimming for long-lived Python service and workspace processes.
# MALLOC_ARENA_MAX=2
# MALLOC_TRIM_THRESHOLD_=131072
# PYTHONMALLOC=malloc
# MCP servers, system prompts, model context config, and shell review risk thresholds are defined per AgentProfile.
# Optional global unattended shell review fallback for schedule/heartbeat runs.
# YA_CLAW_UNATTENDED_SHELL_REVIEW_RISK_THRESHOLD=high

# =============================================================================
# Schedule and Heartbeat Runtime
# =============================================================================
# YA_CLAW_SCHEDULE_DISPATCH_ENABLED=true
# YA_CLAW_SCHEDULE_TICK_SECONDS=5
# YA_CLAW_SCHEDULE_MAX_DUE_PER_TICK=20
# YA_CLAW_HEARTBEAT_ENABLED=false
# YA_CLAW_HEARTBEAT_INTERVAL_SECONDS=300
# YA_CLAW_HEARTBEAT_PROFILE=default
# YA_CLAW_HEARTBEAT_PROMPT=Run heartbeat according to HEARTBEAT.md.
# YA_CLAW_HEARTBEAT_ON_ACTIVE=skip

# =============================================================================
# Session Memory Runtime
# =============================================================================
# YA_CLAW_MEMORY_ENABLED=true
# YA_CLAW_MEMORY_EXTRACT_EVERY_TURNS=5
# YA_CLAW_MEMORY_SUMMARY_EVERY_EXTRACTS=4
# YA_CLAW_MEMORY_EXTRACT_ON_COMPACT=true
# YA_CLAW_MEMORY_EXTRACT_ON_SUMMARIZE=true
# YA_CLAW_MEMORY_INJECT_ENABLED=true
# YA_CLAW_MEMORY_CONTEXT_MAX_CHARS=8000
# YA_CLAW_MEMORY_RECENT_EXTRACTS_LIMIT=5
# YA_CLAW_MEMORY_PROFILE=default

# =============================================================================
# Session Agency Runtime
# =============================================================================
# YA_CLAW_AGENCY_ENABLED=true
# YA_CLAW_AGENCY_IDLE_AFTER_SECONDS=600
# YA_CLAW_AGENCY_COOLDOWN_SECONDS=1800
# YA_CLAW_AGENCY_PROFILE=default
# YA_CLAW_AGENCY_TIMER_INTERVAL_SECONDS=3600
# YA_CLAW_AGENCY_FIRE_BATCH_LIMIT=20
# YA_CLAW_AGENCY_MEMORY_CAPTURE_ENABLED=true
# YA_CLAW_AGENCY_CONTEXT_MAX_CHARS=8000
# YA_CLAW_AGENCY_RECENT_FILES_LIMIT=5
# YA_CLAW_AGENCY_INDEX_TARGET_CHARS=16000
# YA_CLAW_AGENCY_INDEX_MAX_CHARS=32000
# YA_CLAW_AGENCY_ACTION_LOG_RECENT_CHARS=32000
# YA_CLAW_AGENCY_UNATTENDED_SHELL_REVIEW_RISK_THRESHOLD=extra_high

# =============================================================================
# Session and Run Pruning
# =============================================================================
# Background pruning is disabled by default. When enabled, YA Claw prunes old run-store data while
# preserving each session's latest runs, continuity heads, and run database rows.
# YA_CLAW_SESSION_PRUNE_ENABLED=false
# YA_CLAW_SESSION_PRUNE_INTERVAL_SECONDS=86400
# YA_CLAW_SESSION_PRUNE_STARTUP_DELAY_SECONDS=300
# YA_CLAW_SESSION_PRUNE_BATCH_SIZE=1000
# Per-session run retention. The latest N runs are kept for each session.
# YA_CLAW_SESSION_PRUNE_RUN_KEEP_RECENT=10
# Set to a positive day count to only prune runs older than the threshold.
# YA_CLAW_SESSION_PRUNE_RUN_OLDER_THAN_DAYS=0
# Generated session retention covers heartbeat sessions and schedule isolate/fork sessions.
# This deletes session and run database rows for generated sessions, so keep it disabled for metadata-only retention.
# YA_CLAW_SESSION_PRUNE_GENERATED_SESSIONS_ENABLED=false
# YA_CLAW_SESSION_PRUNE_SCHEDULE_KEEP_RECENT=10
# YA_CLAW_SESSION_PRUNE_SCHEDULE_OLDER_THAN_DAYS=30
# YA_CLAW_SESSION_PRUNE_HEARTBEAT_KEEP_RECENT=10
# YA_CLAW_SESSION_PRUNE_HEARTBEAT_OLDER_THAN_DAYS=7
# Fire record retention only affects schedule_fires and heartbeat_fires database rows.
# YA_CLAW_SESSION_PRUNE_FIRE_RECORDS_OLDER_THAN_DAYS=0
# YA_CLAW_SESSION_PRUNE_ORPHANS_ENABLED=true

# =============================================================================
# Graceful Shutdown
# =============================================================================
# Default is unlimited application shutdown wait. Set a positive integer to bound Uvicorn graceful shutdown.
# The application stops schedulers and bridges first, then waits for active run tasks before closing runtime state.
# YA_CLAW_SHUTDOWN_TIMEOUT_SECONDS=600

# =============================================================================
# Bridge Runtime
# =============================================================================
# embedded starts enabled bridge adapters inside the YA Claw HTTP server lifespan.
# manual starts the YA Claw HTTP server without starting BridgeSupervisor.
# YA_CLAW_BRIDGE_DISPATCH_MODE=embedded
# Comma-separated bridge adapters. Current built-in adapter: lark
# YA_CLAW_BRIDGE_ENABLED_ADAPTERS=lark

# Lark / Feishu bridge ingress settings
# YA_CLAW_BRIDGE_LARK_APP_ID=cli_xxx
# YA_CLAW_BRIDGE_LARK_APP_SECRET=replace-with-your-lark-app-secret
# YA_CLAW_BRIDGE_LARK_DEFAULT_PROFILE=default
# YA_CLAW_BRIDGE_LARK_EVENT_TYPES=im.chat.member.bot.added_v1,im.chat.member.user.added_v1,im.message.receive_v1,drive.notice.comment_add_v1
# YA_CLAW_BRIDGE_LARK_REPLY_IDENTITY=bot
# YA_CLAW_BRIDGE_LARK_DOMAIN=https://open.feishu.cn
# YA_CLAW_BRIDGE_LARK_PREVIOUS_MESSAGES_ENABLED=true
# YA_CLAW_BRIDGE_LARK_PREVIOUS_MESSAGES_LIMIT=6
# YA_CLAW_BRIDGE_LARK_PREVIOUS_MESSAGES_MAX_CHARS=4000
# YA_CLAW_BRIDGE_LARK_PREVIOUS_MESSAGE_MAX_CHARS=800

# Workspace lark-cli bot identity. If omitted, YA Claw derives these from the Lark bridge app settings.
# The official Docker workspace entrypoint writes LARK_APP_* values into /home/claw/.lark-cli/config.json.
# LARK_APP_ID=cli_xxx
# LARK_APP_SECRET=replace-with-your-lark-app-secret
# LARKSUITE_CLI_BRAND=feishu
# LARKSUITE_CLI_DEFAULT_AS=bot
# LARKSUITE_CLI_STRICT_MODE=bot

# =============================================================================
# Model Provider / SDK Environment
# =============================================================================
# YA Claw startup now exports non-YA_CLAW variables from packages/ya-claw/.env
# into the process environment. Keep provider keys here for local development.

# GATEWAY_API_KEY=replace-with-your-gateway-key
# GATEWAY_BASE_URL=https://gateway.example.test

# YAACLI CLI environment variables
# Copy this file to packages/yaacli/.env for workspace development,
# or to .env in your current working directory when launching yaacli.
# YAACLI loads these values at startup and passes them through process env.
# SDK and tool variables such as YA_AGENT_*, GOOGLE_SEARCH_API_KEY, and FIRECRAWL_API_KEY
# can also live in this file. Use packages/ya-agent-sdk/.env.example
# as the reference list for those variables.

# =============================================================================
# Display
# =============================================================================

# YAACLI_CODE_THEME=dark
# Console color theme (e.g. tokyo-night, cappuccino). Overrides config.toml [display] theme.
# YAACLI_DISPLAY_THEME=tokyo-night
# YAACLI_SHOW_TOKEN_USAGE=true
# YAACLI_SHOW_ELAPSED_TIME=true

# =============================================================================
# Steering
# =============================================================================

# YAACLI_STEERING_ENABLED=true
# YAACLI_STEERING_PREFIX=>

# =============================================================================
# Session
# =============================================================================

# YAACLI_SESSION_DIR=.yaacli
# YAACLI_AUTO_SAVE_HISTORY=true
# YAACLI_AUTO_RESTORE=true

# =============================================================================
# Agent Stream Recovery
# =============================================================================

# YAACLI_AGENT_STREAM_RESUME_ON_ERROR=true
# YAACLI_AGENT_STREAM_RESUME_MAX_ATTEMPTS=3
# YAACLI_AGENT_STREAM_RESUME_PROMPT=The previous streaming model request failed before the agent finished. Continue the task from the available conversation history. Avoid repeating completed work.

# =============================================================================
# Performance
# =============================================================================

# YAACLI_PERF=1

# =============================================================================
# OAuth Refresh
# =============================================================================

# YAACLI_OAUTH_REFRESH_ENABLED=true
# YAACLI_OAUTH_REFRESH_INTERVAL_SECONDS=1800
# YAACLI_OAUTH_REFRESH_FAILURE_RETRY_SECONDS=60
# YAACLI_OAUTH_REFRESH_ON_STARTUP=true

# =============================================================================
# Model Request Auto Retry
# =============================================================================

# Enables pydantic-ai tenacity-based retries for transient model HTTP requests and
# pre-stream Responses WebSocket failures. Retries respect Retry-After on 429.
# YA_AGENT_MODEL_REQUEST_RETRY_ENABLED=true
# YA_AGENT_MODEL_REQUEST_RETRY_ATTEMPTS=5
# YA_AGENT_MODEL_REQUEST_RETRY_BACKOFF_MULTIPLIER=1
# YA_AGENT_MODEL_REQUEST_RETRY_MAX_WAIT_SECONDS=30
# YA_AGENT_MODEL_REQUEST_RETRY_AFTER_MAX_WAIT_SECONDS=300
# YA_AGENT_MODEL_REQUEST_RETRY_STATUS_CODES=408,409,425,429,500,502,503,504

# =============================================================================
# OpenAI Responses WebSocket Transport
# =============================================================================

# Controls the SDK core OpenAI Responses WebSocket transport used by
# openai-responses-ws:<model> / openai-responses-rs:<model>.
# Allowed values: auto, websocket, http.
# YA_AGENT_OPENAI_RESPONSES_WEBSOCKET_MODE=auto

# Controls the Codex OAuth provider transport for oauth@codex:<model>.
# Allowed values: auto, websocket, http.
# YA_OAUTH_CODEX_RESPONSES_TRANSPORT=auto

# =============================================================================
# Provider API Keys
# =============================================================================

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=...
